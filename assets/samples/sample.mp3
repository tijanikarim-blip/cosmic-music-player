		<style id="wp-custom-css">
			/* ========================================
   CSS Variables for Easy Customization
   ======================================== */
:root {
  /* Colors */
  --color-primary: #4a90e2;
  --color-primary-light: #5cb3ff;
  --color-primary-dark: #3a7bc8;
  --color-accent: #ff6b6b;
  --color-accent-hover: #ff8787;
  --color-dark: #333333;
  --color-gray: #6c757d;
  --color-light-gray: #f8f9fa;
  --color-medium-gray: #e9ecef;
  --color-white: #ffffff;
  
  /* Spacing */
  --spacing-xs: 0.5rem;
  --spacing-sm: 1rem;
  --spacing-md: 1.5rem;
  --spacing-lg: 2rem;
  --spacing-xl: 3rem;
  
  /* Typography */
  --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Arial', sans-serif;
  --font-size-base: 17px;
  --line-height-base: 1.6;
  
  /* Border Radius */
  --radius-sm: 6px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-pill: 50px;
  
  /* Shadows */
  --shadow-sm: 0 2px 4px rgba(0, 0, 0, 0.08);
  --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.12);
  
  /* Transitions */
  --transition-fast: 0.2s ease;
  --transition-base: 0.3s ease;
}

/* ========================================
   AdSense Auto ads
   ======================================== */
.google-auto-placed {
  margin-bottom: var(--spacing-md);
}

/* ========================================
   Base Typography
   ======================================== */
body,
button,
input,
select,
textarea {
  font-family: var(--font-family);
  font-size: var(--font-size-base);
  line-height: var(--line-height-base);
  color: var(--color-dark);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

h1,
h2,
h3,
h4,
h5,
h6 {
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: var(--spacing-sm);
  color: var(--color-dark);
}

h1 {
  font-size: 2.5rem;
  letter-spacing: -0.02em;
}

h2 {
  font-size: 2rem;
  letter-spacing: -0.01em;
}

h3 {
  font-size: 1.5rem;
}

h4 {
  font-size: 1.25rem;
}

h5 {
  font-size: 1.1rem;
}

h6 {
  font-size: 1rem;
}

/* ========================================
   Links
   ======================================== */
a {
  color: var(--color-primary);
  text-decoration: none;
  transition: color var(--transition-base);
  cursor: pointer;
}

a:hover {
  color: var(--color-primary-light);
}

a:focus {
  outline: 2px solid var(--color-primary);
  outline-offset: 2px;
}

/* ========================================
   Buttons
   ======================================== */
.button,
.wp-block-button .wp-block-button__link,
button,
input[type='button'],
input[type='reset'],
input[type='submit'] {
  background-color: var(--color-accent);
  color: var(--color-white);
  padding: 0.75rem 1.75rem;
  border: none;
  border-radius: var(--radius-pill);
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all var(--transition-base);
  display: inline-block;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.button:hover,
.wp-block-button .wp-block-button__link:hover,
button:hover,
input[type='button']:hover,
input[type='reset']:hover,
input[type='submit']:hover {
  background-color: var(--color-accent-hover);
  transform: translateY(-1px);
  box-shadow: var(--shadow-md);
}

.button:active,
button:active,
input[type='button']:active,
input[type='reset']:active,
input[type='submit']:active {
  transform: translateY(0);
}

/* ========================================
   Forms and Input Fields
   ======================================== */
input[type='text'],
input[type='email'],
input[type='url'],
input[type='password'],
input[type='search'],
input[type='tel'],
input[type='number'],
textarea,
select,
.search-field,
.search-modal-form {
  background: var(--color-white);
  border: 2px solid var(--color-medium-gray);
  border-radius: var(--radius-md);
  padding: 0.75rem 1rem;
  font-size: 1rem;
  transition: all var(--transition-base);
  width: 100%;
}

input[type='text']:focus,
input[type='email']:focus,
input[type='url']:focus,
input[type='password']:focus,
input[type='search']:focus,
input[type='tel']:focus,
input[type='number']:focus,
textarea:focus,
select:focus,
.search-field:focus {
  border-color: var(--color-primary);
  outline: none;
  box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.1);
}

textarea {
  resize: vertical;
  min-height: 120px;
}

/* ========================================
   Search Form
   ======================================== */
.search-form {
  display: flex;
  gap: 0;
  max-width: 500px;
}

.search-form .search-field {
  flex-grow: 1;
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
  border-right: none;
}

.search-form .search-submit {
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
  padding: 0.75rem 1.5rem;
}

/* ========================================
   Content Lists
   ======================================== */
.entry-content ul,
.entry-content ol {
  margin: 0 0 var(--spacing-md) 0;
  padding-left: 0;
}

.entry-content ul li,
.entry-content ol li {
  margin-bottom: var(--spacing-xs);
  padding-left: 1.75rem;
  position: relative;
}

/* Custom bullet style */
.entry-content ul {
  list-style: none;
}

.entry-content ul li::before {
  content: '\2022';
  color: var(--color-primary);
  font-weight: bold;
  font-size: 1.2em;
  position: absolute;
  left: 0;
  top: 0;
}

/* Custom number style for ordered lists */
.entry-content ol {
  list-style: none;
  counter-reset: item;
}

.entry-content ol li {
  counter-increment: item;
}

.entry-content ol li::before {
  content: counter(item) '.';
  color: var(--color-primary);
  font-weight: 700;
  position: absolute;
  left: 0;
  top: 0;
  min-width: 1.5rem;
}

.entry-content ul ul,
.entry-content ol ol,
.entry-content ul ol,
.entry-content ol ul {
  margin-top: var(--spacing-xs);
  margin-bottom: 0;
}

/* ========================================
   Tables
   ======================================== */
table {
  border-collapse: collapse;
  width: 100%;
  margin-bottom: var(--spacing-md);
  background-color: var(--color-white);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

th,
td {
  padding: 1rem 1.25rem;
  text-align: left;
  border-bottom: 1px solid var(--color-medium-gray);
}

th {
  background-color: var(--color-light-gray);
  font-weight: 600;
  color: var(--color-dark);
  border-bottom: 2px solid var(--color-medium-gray);
}

tr:last-child td {
  border-bottom: none;
}

tr:hover {
  background-color: rgba(74, 144, 226, 0.02);
}

/* ========================================
   Layout
   ======================================== */
.inside-header {
  padding: var(--spacing-lg) var(--spacing-xl);
}

.site-content {
  padding: var(--spacing-xl) 0;
}

/* ========================================
   Navigation
   ======================================== */
.main-navigation .main-nav ul li a {
  padding: 0.75rem 1.25rem;
  transition: all var(--transition-base);
  border-radius: var(--radius-sm);
}

.main-navigation .main-nav ul li a:hover {
  background-color: rgba(74, 144, 226, 0.08);
}

.main-navigation .main-nav ul ul {
  box-shadow: var(--shadow-md);
  border-radius: var(--radius-md);
  overflow: hidden;
}

/* ========================================
   Cards (Feature & File Type Sections)
   ======================================== */
.feature,
.file-type {
  background-color: var(--color-white);
  border: 1px solid var(--color-medium-gray);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  transition: all var(--transition-base);
}

.feature {
  box-shadow: var(--shadow-md);
}

.feature:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.file-type {
  box-shadow: var(--shadow-sm);
}

.file-type:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-md);
}

/* ========================================
   File Links
   ======================================== */
.file-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
  margin: var(--spacing-sm) 0;
}

.file-list a {
  background-color: var(--color-light-gray);
  color: var(--color-dark);
  border: 2px solid var(--color-primary);
  border-radius: var(--radius-pill);
  padding: 0.5rem 1.25rem;
  font-size: 0.95rem;
  font-weight: 500;
  transition: all var(--transition-base);
  display: inline-flex;
  align-items: center;
}

.file-list a:hover {
  background-color: var(--color-primary);
  color: var(--color-white);
  transform: translateY(-1px);
  box-shadow: var(--shadow-sm);
}

/* ========================================
   Widgets
   ======================================== */
.widget-area .widget {
  padding: var(--spacing-lg);
  background-color: var(--color-white);
  border: 1px solid var(--color-medium-gray);
  box-shadow: var(--shadow-sm);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  transition: box-shadow var(--transition-base);
}

.widget-area .widget:hover {
  box-shadow: var(--shadow-md);
}

.widget-area .widget-title {
  font-size: 1.25rem;
  margin-bottom: var(--spacing-sm);
  padding-bottom: var(--spacing-xs);
  border-bottom: 2px solid var(--color-primary);
}

/* ========================================
   Footer
   ======================================== */
.site-info {
  background-color: var(--color-light-gray);
  color: var(--color-dark);
  padding: var(--spacing-lg) var(--spacing-xl);
  border-top: 1px solid var(--color-medium-gray);
}

/* ========================================
   Comments
   ======================================== */
.comment-content {
  border: 1px solid var(--color-medium-gray);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  background-color: var(--color-white);
  margin-bottom: var(--spacing-sm);
}

/* ========================================
   WordPress Block: Table
   ======================================== */
.wp-block-table {
  overflow-x: auto;
  margin-bottom: var(--spacing-md);
  max-width: 100%;
}

.wp-block-table table {
  border-collapse: collapse;
  width: 100%;
  color: var(--color-dark);
  background-color: var(--color-white);
  box-shadow: var(--shadow-md);
  font-family: var(--font-family);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.wp-block-table thead {
  background: linear-gradient(to bottom, #fafafa, #f7f7f7);
  border-bottom: 2px solid var(--color-primary);
}

.wp-block-table th {
  padding: 1rem 1.25rem;
  text-align: left;
  font-weight: 600;
  border: 1px solid var(--color-medium-gray);
  font-size: 1rem;
}

.wp-block-table tfoot {
  background-color: var(--color-light-gray);
  border-top: 2px solid var(--color-medium-gray);
}

.wp-block-table tfoot td {
  padding: 1rem 1.25rem;
  font-weight: 600;
  border: 1px solid var(--color-medium-gray);
  font-size: 1rem;
}

.wp-block-table td {
  padding: 1rem 1.25rem;
  border: 1px solid var(--color-medium-gray);
  text-align: left;
  font-size: 1rem;
}

.wp-block-table tbody tr:hover {
  background-color: rgba(74, 144, 226, 0.03);
}

/* ========================================
   WordPress Block: Separator
   ======================================== */
.wp-block-separator {
  border: 0;
  border-top: 2px solid var(--color-medium-gray);
  margin: var(--spacing-xl) 0;
  opacity: 0.6;
}

.wp-block-separator.is-style-wide {
  border-top-width: 2px;
}

.wp-block-separator.is-style-dots::before {
  color: var(--color-primary);
}

/* ========================================
   Accessibility
   ======================================== */
.screen-reader-text:focus {
  background-color: var(--color-light-gray);
  border-radius: var(--radius-sm);
  box-shadow: 0 0 2px 2px rgba(0, 0, 0, 0.6);
  clip: auto !important;
  color: var(--color-primary);
  display: block;
  font-size: 14px;
  font-weight: 600;
  height: auto;
  left: 5px;
  line-height: normal;
  padding: 15px 23px 14px;
  text-decoration: none;
  top: 5px;
  width: auto;
  z-index: 100000;
}

/* Skip to content link */
.skip-link {
  position: absolute;
  top: -40px;
  left: 0;
  background: var(--color-primary);
  color: var(--color-white);
  padding: 8px 16px;
  text-decoration: none;
  border-radius: 0 0 var(--radius-sm) 0;
  z-index: 100;
}

.skip-link:focus {
  top: 0;
}

/* ========================================
   Utility Classes
   ======================================== */
.text-center {
  text-align: center;
}

.text-muted {
  color: var(--color-gray);
}

.mt-1 { margin-top: var(--spacing-xs); }
.mt-2 { margin-top: var(--spacing-sm); }
.mt-3 { margin-top: var(--spacing-md); }
.mt-4 { margin-top: var(--spacing-lg); }

.mb-1 { margin-bottom: var(--spacing-xs); }
.mb-2 { margin-bottom: var(--spacing-sm); }
.mb-3 { margin-bottom: var(--spacing-md); }
.mb-4 { margin-bottom: var(--spacing-lg); }

/* ========================================
   Responsive Design
   ======================================== */
@media (max-width: 1024px) {
  :root {
    --font-size-base: 16px;
  }
  
  h1 {
    font-size: 2.25rem;
  }
  
  h2 {
    font-size: 1.875rem;
  }
}

@media (max-width: 768px) {
  :root {
    --spacing-xl: 2rem;
    --spacing-lg: 1.5rem;
  }
  
  .inside-header {
    padding: var(--spacing-md) var(--spacing-lg);
  }

  .site-content {
    padding: var(--spacing-lg) 0;
  }

  .widget-area .widget {
    padding: var(--spacing-md);
  }
  
  .site-info {
    padding: var(--spacing-md) var(--spacing-lg);
  }
  
  h1 {
    font-size: 2rem;
  }
  
  h2 {
    font-size: 1.75rem;
  }
  
  .feature,
  .file-type {
    padding: var(--spacing-md);
  }
  
  .file-list a {
    font-size: 0.9rem;
    padding: 0.4rem 1rem;
  }
  
  th,
  td {
    padding: 0.75rem;
  }
}

@media (max-width: 480px) {
  :root {
    --spacing-xl: 1.5rem;
    --spacing-lg: 1rem;
  }
  
  .inside-header {
    padding: var(--spacing-sm) var(--spacing-md);
  }

  .site-content {
    padding: var(--spacing-md) 0;
  }
  
  h1 {
    font-size: 1.75rem;
  }
  
  h2 {
    font-size: 1.5rem;
  }
  
  h3 {
    font-size: 1.25rem;
  }
  
  .button,
  button,
  input[type='button'],
  input[type='reset'],
  input[type='submit'] {
    padding: 0.65rem 1.5rem;
    font-size: 0.9rem;
  }
  
  th,
  td {
    padding: 0.5rem;
    font-size: 0.9rem;
  }
}

/* ========================================
   Print Styles
   ======================================== */
@media print {
  .no-print,
  .widget-area,
  .site-info,
  button,
  .button {
    display: none !important;
  }
  
  body {
    color: #000;
    background: #fff;
  }
  
  a {
    text-decoration: underline;
  }
}

/* ========================================
   Dark Mode Support (Optional)
   ======================================== */
@media (prefers-color-scheme: dark) {
  /* Uncomment to enable dark mode
  :root {
    --color-dark: #f8f9fa;
    --color-white: #1a1a1a;
    --color-light-gray: #2d2d2d;
    --color-medium-gray: #404040;
  }
  
  body {
    background-color: #1a1a1a;
  }
  */
}

/* ========================================
   Performance: Reduce Motion
   ======================================== */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}		</style>
