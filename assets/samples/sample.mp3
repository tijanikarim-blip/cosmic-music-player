<link rel='stylesheet' id='addtoany-css' href='https://sample-files.com/wp-content/plugins/add-to-any/addtoany.min.css?ver=1.16' media='all' />
<style id='addtoany-inline-css'>
/* Hide ALL AddToAny on homepage */
body.home .a2a_kit,
body.home .a2a_floating_style,
body.front-page .a2a_kit,
body.front-page .a2a_floating_style {
  display: none !important;
}

/* Align Share label + icons */
.addtoany_content {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  margin: 60px auto;
}

/* Share label */
.addtoany_header {
  margin: 0 !important;
  font-weight: 500;
  color: #333333;
  display: flex;
  align-items: center;
}

/* Icon row */
.addtoany_list {
  display: flex;
  align-items: center;
  gap: 4px;
  line-height: 0;
}

/* Make icons perfectly circular */
.addtoany_list a:not(.addtoany_special_service) > span {
  border-radius: 50% !important;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* Image-based icons */
.addtoany_list a img {
  border-radius: 50% !important;
  display: block;
}

/* Optional subtle hover */
.addtoany_list a {
  transition: transform 0.2s ease;
}

.addtoany_list a:hover {
  transform: scale(1.08);
}
/*# sourceURL=addtoany-inline-css */
</style>
